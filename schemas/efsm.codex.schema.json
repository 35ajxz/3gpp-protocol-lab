{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex EFSM Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "release",
    "source_document",
    "procedure",
    "messages",
    "timers",
    "variables",
    "transitions"
  ],
  "properties": {
    "spec": {
      "type": "string"
    },
    "release": {
      "type": "string"
    },
    "source_document": {
      "type": "string"
    },
    "procedure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "slug"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        }
      }
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step",
          "source_state",
          "event",
          "guard",
          "actions",
          "target_state",
          "refs"
        ],
        "properties": {
          "step": {
            "type": "integer"
          },
          "source_state": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "guard": {
            "type": [
              "string",
              "null"
            ]
          },
          "actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "target_state": {
            "type": "string"
          },
          "refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
