-- Auto-generated bootstrap NuSMV for 5.3.3 RRC connection establishment
MODULE main
VAR state : {RRC_CONNECTED, RRC_IDLE, RRC_SETUP_REQUESTED};
ASSIGN
  init(state) := RRC_IDLE;
  next(state) := case
    state = RRC_IDLE : RRC_SETUP_REQUESTED;
    state = RRC_SETUP_REQUESTED : RRC_CONNECTED; -- guard: fullConfig_present
    state = RRC_SETUP_REQUESTED : RRC_IDLE;
    TRUE : state;
  esac;
