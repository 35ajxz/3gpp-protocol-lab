{
  "spec": "TS 38.331",
  "release": "Rel-17",
  "source_document": "5.3.13-rrc-connection-resume.md",
  "procedure": {
    "id": "5.3.13",
    "title": "RRC connection resume",
    "slug": "5.3.13-rrc-connection-resume"
  },
  "messages": [
    "RRCResumeRequest",
    "RRCResume",
    "RRCReject"
  ],
  "timers": [
    "T319"
  ],
  "variables": [
    "fullConfig",
    "masterCellGroup",
    "radioBearerConfig",
    "skCounter",
    "suspendConfig",
    "resumeIdentity"
  ],
  "transitions": [
    {
      "step": 1,
      "source_state": "RRC_INACTIVE",
      "event": "upper_layers_resume_request",
      "guard": null,
      "actions": [
        "start_timer(T319)",
        "send_message(RRCResumeRequest,resumeIdentity)"
      ],
      "target_state": "RRC_RESUME_REQUESTED",
      "refs": [
        "5.3.13.2"
      ]
    },
    {
      "step": 2,
      "source_state": "RRC_RESUME_REQUESTED",
      "event": "receive(RRCResume)",
      "guard": "fullConfig_present",
      "actions": [
        "stop_timer(T319)",
        "perform_full_configuration",
        "release_suspendConfig_keep_rna"
      ],
      "target_state": "RRC_CONNECTED",
      "refs": [
        "5.3.13.4",
        "5.3.5.11"
      ]
    },
    {
      "step": 3,
      "source_state": "RRC_RESUME_REQUESTED",
      "event": "receive(RRCResume)",
      "guard": "not fullConfig_present and masterCellGroup_present",
      "actions": [
        "stop_timer(T319)",
        "apply_masterCellGroup_delta",
        "update_radioBearerConfig_if_present",
        "update_skCounter_if_present"
      ],
      "target_state": "RRC_CONNECTED",
      "refs": [
        "5.3.13.4"
      ]
    },
    {
      "step": 4,
      "source_state": "RRC_RESUME_REQUESTED",
      "event": "receive(RRCReject)",
      "guard": null,
      "actions": [
        "stop_timer(T319)",
        "clear_resume_context"
      ],
      "target_state": "RRC_IDLE",
      "refs": [
        "5.3.13.6"
      ]
    },
    {
      "step": 5,
      "source_state": "RRC_RESUME_REQUESTED",
      "event": "timer_expiry(T319)",
      "guard": null,
      "actions": [
        "clear_resume_context",
        "reselect_cell"
      ],
      "target_state": "RRC_IDLE",
      "refs": [
        "5.3.13.7"
      ]
    }
  ]
}
